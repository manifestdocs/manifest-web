{
  "name": "@manifestdocs/app",
  "version": "0.1.27",
  "description": "Living feature documentation for AI-driven development",
  "type": "module",
  "license": "BSL-1.1",
  "bin": {
    "manifest": "bin/manifest.js"
  },
  "files": [
    "build",
    "bin",
    "package.json"
  ],
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "api:generate": "openapi-typescript ./design/openapi.yaml -o src/lib/api/schema.d.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/diff": "^8.0.0",
    "@types/node": "^25.3.0",
    "jsdom": "^27.4.0",
    "openapi-typescript": "^7.10.1",
    "svelte": "^5.45.6",
    "svelte-check": "^4.3.4",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.0.17"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@libsql/client": "^0.17.0",
    "@manifest/svelte": "workspace:*",
    "bits-ui": "^1.0.0-next.98",
    "clsx": "^2.1.1",
    "diff": "^8.0.3",
    "dompurify": "^3.3.1",
    "highlight.js": "^11.11.1",
    "marked": "^17.0.1",
    "marked-highlight": "^2.2.3",
    "openapi-fetch": "^0.15.0",
    "paneforge": "^1.0.2",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "zod": "^4.3.6"
  }
}
