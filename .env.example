# Clerk Authentication (required for cloud mode)
# Get these from your Clerk dashboard: https://dashboard.clerk.com
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Deployment Mode (must be PUBLIC_ prefixed for client access)
# Set to 'cloud' for production with authentication
# Leave unset or 'local' for local development without auth
PUBLIC_MANIFEST_MODE=local

# API Server URL (optional, defaults to http://localhost:17010/api/v1)
MANIFEST_API_URL=http://localhost:17010/api/v1
